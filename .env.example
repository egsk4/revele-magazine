# ══════════════════════════════════════════════════════════════
#  RÉVÈLE MAGAZINE — Environment Variables
#  Copy this file to .env for local dev, then set these on Render
#  NEVER commit .env to git (it's in .gitignore)
# ══════════════════════════════════════════════════════════════

# ─── SERVER ────────────────────────────────────────────────────
PORT=3001
NODE_ENV=production

# Your production domain (used for CORS)
ALLOWED_ORIGINS=https://revelemagazine.com,https://www.revelemagazine.com

# ─── ADMIN ─────────────────────────────────────────────────────
# Use a strong random password. Generate one at: https://1password.com/password-generator/
ADMIN_PASSWORD=your-very-strong-password-here

# ─── DISCORD WEBHOOKS ──────────────────────────────────────────
# Regenerate these in Discord: Server Settings → Integrations → Webhooks
# The old URLs were exposed in the repo and should be considered compromised.
SUBMISSIONS_WEBHOOK=https://discord.com/api/webhooks/YOUR_NEW_WEBHOOK_ID/YOUR_NEW_TOKEN
NEWSLETTER_WEBHOOK=https://discord.com/api/webhooks/YOUR_NEW_WEBHOOK_ID/YOUR_NEW_TOKEN

# ─── EMAIL (Resend — free 100/day at resend.com) ──────────────
# 1. Sign up free at https://resend.com
# 2. Add & verify your domain (revelemagazine.com)
# 3. Create an API key
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
FROM_EMAIL=submissions@revelemagazine.com
FROM_NAME=Révèle Magazine

# ─── CLOUDFLARE R2 (free 10 GB storage, zero egress fees) ─────
# 1. Go to https://dash.cloudflare.com → R2 → Create bucket
#    Bucket name: revele-submissions
# 2. R2 → Manage R2 API Tokens → Create Token (Object Read & Write)
# 3. Copy the values below from the token creation screen
R2_ACCOUNT_ID=your_cloudflare_account_id
R2_ACCESS_KEY_ID=your_r2_access_key_id
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key
R2_BUCKET=revele-submissions
# Public URL — set up a custom domain on your R2 bucket for this, OR leave blank
# to keep uploads private (accessible only via signed URLs)
R2_PUBLIC_URL=https://uploads.revelemagazine.com

# ─── DATABASE ──────────────────────────────────────────────────
# Leave blank to use the default path (./revele.db) — fine for Render with a disk
DB_PATH=./revele.db
